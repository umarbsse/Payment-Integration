# Option 1: Using php-dotenv library (Recommended)
# 
# require_once __DIR__ . '/vendor/autoload.php';
# $dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
# $dotenv->load();
# 
# $stripeSecret = $_ENV['STRIPE_SECRET_KEY'];
# 
# 
