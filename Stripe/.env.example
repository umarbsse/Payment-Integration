# Stripe Payment Integration - Environment Variables Example
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual Stripe API keys
# 3. Add .env to .gitignore (never commit real keys!)
# 4. In your PHP code, load this with a library like:
#    - php-dotenv (https://github.com/vlucas/phpdotenv)
#    - Or manually with: $key = getenv('STRIPE_SECRET_KEY');
#
# SECURITY:
# - This file should NOT be committed to version control
# - Never share your secret key (starts with sk_)
# - The .env file is already in .gitignore

# ============================================================================
# STRIPE API CREDENTIALS
# ============================================================================

# Get these from: https://dashboard.stripe.com/apikeys

# Stripe Secret Key - KEEP THIS PRIVATE
# Test: sk_test_...
# Live: sk_live_...
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Stripe Publishable Key - Safe to expose to frontend
# Test: pk_test_...
# Live: pk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name
APP_NAME="My Payment Application"

# Base URL of your application
# Development: http://localhost/stripe
# Production: https://yourdomain.com
APP_URL=http://localhost/stripe

# Default currency (ISO 4217 code)
DEFAULT_CURRENCY=usd

# ============================================================================
# PAYMENT SETTINGS
# ============================================================================

# Minimum payment amount in cents (50 = $0.50)
MIN_PAYMENT_AMOUNT=50

# Maximum payment amount in cents (999999 = $9,999.99)
MAX_PAYMENT_AMOUNT=999999

# ============================================================================
# LOGGING AND DEBUG
# ============================================================================

# Enable debug mode (true for development, false for production)
DEBUG_MODE=true

# Path to log file
LOG_FILE_PATH=/var/log/stripe_api.log
# Or for local development:
# LOG_FILE_PATH=./logs/stripe_api.log

# ============================================================================
# WEBHOOK SETTINGS (Optional)
# ============================================================================

# Webhook signing secret from Stripe Dashboard
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET_HERE

# ============================================================================
# DATABASE (Optional - for order storage)
# ============================================================================

# DB_HOST=localhost
# DB_USER=stripe_user
# DB_PASSWORD=your_secure_password
# DB_NAME=stripe_payments

# ============================================================================
# EMAIL SETTINGS (Optional - for confirmations)
# ============================================================================

# MAIL_FROM=noreply@example.com
# MAIL_SMTP_HOST=smtp.mailtrap.io
# MAIL_SMTP_PORT=2525
# MAIL_SMTP_USER=your_username
# MAIL_SMTP_PASS=your_password

# ============================================================================
