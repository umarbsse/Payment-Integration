# Stripe Payment Integration - Git Ignore File
# Prevents sensitive files from being committed to version control

# ============================================================================
# Configuration Files with Sensitive Data
# ============================================================================

# Local configuration with hardcoded keys (NOT recommended, but if you use it)
config.local.php
local.config.php

# Environment files
.env
.env.local
.env.*.local

# ============================================================================
# Logs and Temporary Files
# ============================================================================

# Debug logs with sensitive payment information
logs/
*.log

# Temporary files
*.tmp
*.temp
temp/

# ============================================================================
# IDE and Editor Files
# ============================================================================

# VSCode
.vscode/
*.code-workspace

# PhpStorm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.vim/
*.swp
*.swo
*~

# Nano
.nanorc

# ============================================================================
# OS-Specific Files
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ============================================================================
# Deployment and Build Files
# ============================================================================

# Node modules (if using task runners)
node_modules/
npm-debug.log

# Composer vendor (if added)
vendor/
composer.lock

# PHP-FPM
php-fpm.socket

# ============================================================================
# Database Files
# ============================================================================

# SQLite databases
*.sqlite
*.sqlite3
*.db

# ============================================================================
# Backup Files
# ============================================================================

*.bak
*.backup
*.old
*.orig

# ============================================================================
# Important: NEVER ignore these - they contain the logic
# ============================================================================

# DO NOT ADD PATTERNS THAT WOULD IGNORE:
# !/config.php                 - Contains structure (not secrets if using env vars)
# !/stripe_client.php          - Core API client
# !/create_payment.php         - Payment creation logic
# !/success.php                - Success page
# !/cancel.php                 - Cancel page
# !/checkout_session.php       - Alternative implementation
# !/README.md                  - Documentation
# !/example_form.php           - Example forms
# !/example_checkout_form.php  - Alternative form example
